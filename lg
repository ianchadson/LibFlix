#!/usr/bin/env python3
import re, sys, os, textwrap, warnings
from urllib.parse import urljoin
from dataclasses import dataclass

import requests
from bs4 import BeautifulSoup
from colorama import init, Fore, Style

warnings.filterwarnings("ignore", category=requests.packages.urllib3.exceptions.InsecureRequestWarning)
init(autoreset=True)

MIRROR = "https://libgen.li"

@dataclass
class Book:
    id: str = ""
    title: str = ""
    author: str = ""
    series: str = ""
    publisher: str = ""
    year: str = ""
    language: str = ""
    pages: str = ""
    size: str = ""
    ext: str = ""
    md5: str = ""
    file_id: str = ""

def fetch_search(query, sort="y", order="DESC", page=1, res=25):
    params = {
        "req": query,
        "columns[]": ["t", "a", "s", "y", "p", "i", "l", "la", "qi"],
        "sort": sort,
        "sortmode": order,
        "page": page,
        "res": res,
        "topics[]": ["l", "f", "a"],
        "curtab": "f",
    }
    r = requests.get(f"{MIRROR}/index.php", params=params, timeout=30,
                     headers={"User-Agent": "Mozilla/5.0"})
    r.raise_for_status()
    return r.text

def parse_results(html_text):
    soup = BeautifulSoup(html_text, "html.parser")
    table = soup.find("table", id="tablelibgen")
    if not table:
        return []
    books = []
    rows = table.find_all("tr")
    for row in rows[1:]:
        cells = row.find_all("td")
        if len(cells) < 9:
            continue
        tds = []
        for td in row.find_all("td"):
            tds.append(td)
        md5 = ""
        file_id = ""
        mirror_cell = tds[-1]
        mlink = mirror_cell.find("a")
        if mlink and mlink.get("href"):
            m = re.search(r'md5=([a-f0-9]{32})', mlink["href"])
            if m:
                md5 = m.group(1)
        first_cell = tds[0]
        first_html = str(first_cell)
        fm = re.search(r'ID:\s*(\d+)', first_html)
        if fm:
            file_id = fm.group(1)
        link_a = first_cell.find("a")
        title = link_a.get_text(strip=True) if link_a else first_cell.get_text(strip=True)
        title = re.sub(r'\s+', ' ', title).strip()
        author = tds[1].get_text(" ", strip=True) if len(tds) > 1 else ""
        series = ""
        publisher = tds[2].get_text(" ", strip=True) if len(tds) > 2 else ""
        year = tds[3].get_text(" ", strip=True) if len(tds) > 3 else ""
        year = re.sub(r'[;|].*$', '', year).strip()
        year = re.sub(r'\s+P\s+\d+.*$', '', year).strip()
        language = tds[4].get_text(" ", strip=True) if len(tds) > 4 else ""
        pages = tds[5].get_text(" ", strip=True) if len(tds) > 5 else ""
        size_link = tds[6].find("a") if len(tds) > 6 else None
        size = size_link.get_text(strip=True) if size_link else (tds[6].get_text(" ", strip=True) if len(tds) > 6 else "")
        ext = tds[7].get_text(" ", strip=True) if len(tds) > 7 else ""
        books.append(Book(
            id=file_id, title=title, author=author, series=series,
            publisher=publisher, year=year, language=language,
            pages=pages, size=size, ext=ext, md5=md5, file_id=file_id
        ))
    return books

def get_total_pages(html_text):
    soup = BeautifulSoup(html_text, "html.parser")
    paginator = soup.find("div", class_="paginator")
    if paginator:
        m = re.search(r'Paginator\("(\w+)",\s*(\d+)', str(paginator))
        if m:
            total = int(m.group(2))
            res = 25
            rm = re.search(r'res=(\d+)', str(paginator))
            return (total + res - 1) // res
    return 1

def resolve_download(md5):
    try:
        r = requests.get(f"{MIRROR}/ads.php", params={"md5": md5}, timeout=30,
                         headers={"User-Agent": "Mozilla/5.0"}, allow_redirects=True)
        r.raise_for_status()
        soup = BeautifulSoup(r.text, "html.parser")
        for a in soup.find_all("a"):
            href = a.get("href", "")
            if "get.php" in href or "download" in href.lower() or "/dl/" in href:
                return urljoin(r.url, href)
        for a in soup.find_all("a"):
            href = a.get("href", "")
            if href.startswith("http") and ("libgen" in href or "booksdl" in href):
                return urljoin(r.url, href)
        txt = r.text
        m = re.search(r'https?://[^"\']+\.(?:epub|pdf|mobi|djvu|zip|rar)[^"\']*', txt, re.I)
        if m:
            return m.group(0)
        m = re.search(r'(?:href|HREF)=["\']([^"\']+)["\']', txt)
        if m:
            return urljoin(r.url, m.group(1))
    except Exception:
        return f"https://libgen.li/ads.php?md5={md5}"
    return f"https://libgen.li/ads.php?md5={md5}"

def parse_size(size_str):
    size_str = size_str.strip().upper()
    m = re.match(r'([\d.]+)\s*(KB|MB|GB|B)', size_str)
    if not m:
        try:
            return float(size_str.replace(",", ""))
        except:
            return 0
    val = float(m.group(1))
    unit = m.group(2)
    if unit == "B": return val
    if unit == "KB": return val * 1024
    if unit == "MB": return val * 1024 * 1024
    if unit == "GB": return val * 1024 * 1024 * 1024
    return val

def format_size(bytes_val):
    if bytes_val >= 1024*1024*1024:
        return f"{bytes_val/(1024*1024*1024):.1f} GB"
    if bytes_val >= 1024*1024:
        return f"{bytes_val/(1024*1024):.1f} MB"
    if bytes_val >= 1024:
        return f"{bytes_val/1024:.1f} KB"
    return f"{bytes_val:.0f} B"

def pretty(books):
    if not books:
        print(f"{Fore.YELLOW}No results found.")
        return
    print(f"\n{Fore.CYAN}{'#':<4} {'Title':<60} {'Author':<25} {'Year':<6} {'Size':<10} {'Ext':<6} {'Lang':<8}")
    print(f"{Fore.CYAN}{'-'*130}")
    for i, b in enumerate(books, 1):
        title = b.title[:57] + "..." if len(b.title) > 60 else b.title
        author = b.author[:22] + "..." if len(b.author) > 25 else b.author
        color = Fore.GREEN if b.ext.lower() == "epub" else Fore.WHITE
        print(f"{color}{i:<4} {title:<60} {author:<25} {b.year:<6} {b.size:<10} {b.ext:<6} {b.language:<8}")

def do_download(book, output_dir="."):
    os.makedirs(output_dir, exist_ok=True)
    url = resolve_download(book.md5)
    safe_title = re.sub(r'[^\w\s-]', '', book.title).strip()[:80]
    fname = f"{safe_title}.{book.ext}" if book.ext else f"{safe_title}.epub"
    fpath = os.path.join(output_dir, fname)
    print(f"{Fore.CYAN}Downloading: {book.title}")
    print(f"{Fore.CYAN}From: {url}")
    try:
        r = requests.get(url, stream=True, timeout=120,
                         headers={"User-Agent": "Mozilla/5.0"}, allow_redirects=True)
        r.raise_for_status()
        total = int(r.headers.get("content-length", 0))
        dl = 0
        next_report = 1024 * 1024
        with open(fpath, "wb") as f:
            for chunk in r.iter_content(chunk_size=8192):
                if chunk:
                    f.write(chunk)
                    dl += len(chunk)
                    if total and dl >= next_report:
                        pct = dl / total * 100
                        sys.stdout.write(f"\r{Fore.GREEN}Downloading: {pct:.0f}% ({format_size(dl)}/{format_size(total)})")
                        sys.stdout.flush()
                        next_report = dl + 1024 * 1024
        if total:
            print(f"\r{Fore.GREEN}Downloading: 100% ({format_size(total)}/{format_size(total)})")
        print(f"{Fore.GREEN}Saved: {fpath}")
    except Exception as e:
        print(f"{Fore.RED}Download failed: {e}")

def main():
    import argparse
    parser = argparse.ArgumentParser(
        description="libgen.li CLI - search and download English EPUBs",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            examples:
              lg "python programming"
              lg "dune" --sort year --order asc
              lg "clean code" --filter-format epub --lang-filter English --limit 50
              lg "the hobbit" --sort year --dl 1
              lg "learn python" --all-langs --no-format-filter
        """)
    )
    parser.add_argument("query", help="search query")
    parser.add_argument("--sort", default="y", choices=["y", "year", "id", "title", "author", "filesize", "extension", "time_added"],
                        help="sort field: y/year, id, title, author, filesize, extension, time_added (default: y)")
    parser.add_argument("--order", default="DESC", choices=["ASC", "DESC", "asc", "desc"],
                        help="sort order (default: DESC)")
    parser.add_argument("--limit", type=int, default=25, choices=[25, 50, 100],
                        help="results per page (default: 25)")
    parser.add_argument("--pages", type=int, default=1,
                        help="number of pages to fetch (default: 1)")
    parser.add_argument("--dl", type=int, default=0,
                        help="download result number directly (one-click)")
    parser.add_argument("--output", "-o", default=".",
                        help="download output directory (default: .)")
    parser.add_argument("--filter-format", default="epub",
                        help="filter by format (default: epub, set to '' for all)")
    parser.add_argument("--lang-filter", default="English",
                        help="filter by language (default: English, set to '' for all)")
    parser.add_argument("--all-langs", action="store_true",
                        help="include all languages (overrides --lang-filter)")
    parser.add_argument("--no-format-filter", action="store_true",
                        help="include all formats (overrides --filter-format)")
    parser.add_argument("--interactive", "-i", action="store_true",
                        help="interactive mode - pick a result to download")

    args = parser.parse_args()

    sort_field = "y" if args.sort == "year" else args.sort
    order_val = args.order.upper()
    html_text = fetch_search(args.query, sort=sort_field, order=order_val, page=1, res=args.limit)
    books = parse_results(html_text)
    total_p = get_total_pages(html_text)

    if args.pages > 1:
        for p in range(2, min(args.pages, total_p) + 1):
            h = fetch_search(args.query, sort=sort_field, order=order_val, page=p, res=args.limit)
            books.extend(parse_results(h))

    lang_filter = None if args.all_langs else (args.lang_filter or None)
    fmt_filter = None if args.no_format_filter else (args.filter_format or None)

    filtered = []
    for b in books:
        if lang_filter and b.language.lower() != lang_filter.lower():
            continue
        if fmt_filter and b.ext.lower() != fmt_filter.lower():
            continue
        filtered.append(b)

    books = filtered

    if not books:
        print(f"{Fore.YELLOW}No matching results found.")
        return

    if args.dl:
        if args.dl < 1 or args.dl > len(books):
            print(f"{Fore.RED}Invalid index. Choose 1-{len(books)}")
            sys.exit(1)
        do_download(books[args.dl - 1], args.output)
        return

    pretty(books)

    if args.interactive:
        print()
        try:
            choice = input(f"{Fore.CYAN}Enter number to download (or q to quit): {Style.RESET_ALL}").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return
        if choice.lower() in ("q", ""):
            return
        try:
            idx = int(choice)
            if 1 <= idx <= len(books):
                do_download(books[idx - 1], args.output)
            else:
                print(f"{Fore.RED}Invalid. Choose 1-{len(books)}")
        except ValueError:
            print(f"{Fore.RED}Invalid input.")

if __name__ == "__main__":
    main()
